{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "storybook build -o storybook-static",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test:a11y": "test-storybook --url http://127.0.0.1:6006",
    "test:a11y:ci": "concurrently -k -s first -n SB,A11Y \"http-server storybook-static --port 6006 -s\" \"wait-on http://127.0.0.1:6006 && test-storybook --url http://127.0.0.1:6006\"",
    "visual": "playwright test",
    "visual:update": "playwright test --update-snapshots",
    "visual:report": "playwright show-report"
  },
  "dependencies": {
    "@sym/ui": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@playwright/test": "^1.59.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@storybook/addon-a11y": "^8.3.0",
    "@storybook/addon-essentials": "^8.3.0",
    "@storybook/addon-themes": "^8.6.18",
    "@storybook/blocks": "^8.3.0",
    "@storybook/react": "^8.3.0",
    "@storybook/react-vite": "^8.3.0",
    "@storybook/test-runner": "^0.19.1",
    "@tanstack/react-table": "^8.21.3",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "axe-playwright": "^2.0.3",
    "concurrently": "^9.0.1",
    "http-server": "^14.1.1",
    "lucide-react": "^1.14.0",
    "postcss": "^8.4.47",
    "react-hook-form": "^7.73.1",
    "storybook": "^8.3.0",
    "tailwindcss": "^3.4.13",
    "vite": "^5.4.8",
    "wait-on": "^8.0.1",
    "zod": "^4.3.6"
  }
}
